        "tags": ["music", "cyberpunk", "electronic", "synthwave"],
        "preferredDuration": { "min": 60, "max": 300 }
      }
    },
    "historical": {
      "footstep": {
        "queries": ["footstep dirt", "footstep wooden floor", "boots gravel"],
        "tags": ["footstep", "walking", "historical"],
        "preferredDuration": { "min": 0.2, "max": 1.0 }
      },
      "ambient": {
        "queries": ["western town ambience", "desert wind", "saloon piano", "horse neighing"],
        "tags": ["ambience", "atmosphere", "western", "historical"],
        "preferredDuration": { "min": 30, "max": 300 }
      },
      "combat": {
        "queries": ["revolver shot", "rifle shot", "fist punch", "whip crack"],
        "tags": ["combat", "weapon", "gun", "western"],
        "preferredDuration": { "min": 0.3, "max": 2.0 }
      },
      "interact": {
        "queries": ["saloon door swing", "drawer open wood", "bottle clink", "paper rustling"],
        "tags": ["interact", "door", "wood", "historical"],
        "preferredDuration": { "min": 0.2, "max": 3.0 }
      },
      "music": {
        "queries": ["western music", "frontier guitar", "harmonica western"],
        "tags": ["music", "western", "acoustic", "historical"],
        "preferredDuration": { "min": 60, "max": 300 }
      }
    },
    "generic": {
      "footstep": {
        "queries": ["footstep", "walking sound", "boots walking"],
        "tags": ["footstep", "walking"],
        "preferredDuration": { "min": 0.2, "max": 1.0 }
      },
      "ambient": {
        "queries": ["nature ambience", "outdoor atmosphere", "wind gentle"],
        "tags": ["ambience", "atmosphere", "nature"],
        "preferredDuration": { "min": 30, "max": 300 }
      },
      "combat": {
        "queries": ["punch hit", "impact sound", "weapon swing"],
        "tags": ["combat", "impact", "hit"],
        "preferredDuration": { "min": 0.3, "max": 2.0 }
      },
      "interact": {
        "queries": ["door open", "item pickup", "button click"],
        "tags": ["interact", "pickup", "door"],
        "preferredDuration": { "min": 0.2, "max": 3.0 }
      },
      "music": {
        "queries": ["adventure music", "exploration ambient", "calm instrumental"],
        "tags": ["music", "adventure", "instrumental"],
        "preferredDuration": { "min": 60, "max": 300 }
      }
    }
  }
}
