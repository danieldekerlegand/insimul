/**
 * Babylon.js Exporter - Updated to use actual 3DGame files
 */

import * as fs from 'fs/promises';
import * as fsSync from 'fs';
import * as path from 'path';
import { execSync } from 'child_process';
import { mkdtemp, rm } from 'fs/promises';
import { join } from 'path';
import { tmpdir } from 'os';
import { createRequire } from 'module';
import { mkdir as fsMkdir, writeFile as fsWriteFile } from 'fs/promises';
import type { WorldIR } from '@shared/game-engine/ir-types';
import type { GeneratedFile } from './babylon-project-generator';
import { generateDataFiles } from './babylon-data-generator';
import { generateSceneFiles } from './babylon-scene-generator';
import { generateProjectFiles } from './babylon-project-generator';
import { GameFileCopier } from './game-file-copier';
import { copySharedTypes } from '../shared-files-copier';
import { bundleAssetsFromCollection, bundleCoreAssets } from '../asset-bundler';
import type { BundleResult, BundledAsset } from '../asset-bundler';
import { generateWorldIR } from '../ir-generator';
import type { BabylonExportOptions } from './types';

// createRequire needed for ESM projects.
const require = createRequire(import.meta.url);
let archiver: any;

// ============================================================================
// SHARED TYPES COPY FUNCTION
// ============================================================================

async function copySharedTypes(): Promise<GeneratedFile[]> {
  const files: GeneratedFile[] = [];
  const sharedPath = path.join(process.cwd(), 'shared');
  
  console.log(`[Export] Copying all files from shared directory: ${sharedPath}`);
  
  // Copy all files recursively from the shared directory
  const copyAllFiles = function(dir: string, basePath: string = ''): void {
    const entries = fs.readdirSync(dir, { withFileTypes: true });
    
    for (const entry of entries) {
      const fullPath = path.join(dir, entry.name);
      const relativePath = basePath ? path.join(basePath, entry.name) : entry.name;
      
      if (entry.isDirectory()) {
        copyAllFiles(fullPath, relativePath);
      } else {
        const content = fs.readFileSync(fullPath, 'utf8');
        files.push({
          path: `src/shared/${relativePath}`,
          content
        });
        console.log(`[Export] Copied: shared/${relativePath}`);
      }
    }
  };
  
  if (fs.existsSync(sharedPath)) {
    copyAllFiles(sharedPath);
  } else {
    console.log(`[Export] Warning: Shared directory not found at ${sharedPath}`);
  }
  
  console.log(`[Export] Total files copied from shared: ${files.length}`);
  return files;
}

// ============================================================================
// MAIN EXPORT FUNCTION
// ============================================================================

/**
 * Export a Babylon.js project with the actual 3DGame files
 */
export async function exportBabylonProject(worldId: string, options: BabylonExportOptions = { mode: 'web' }): Promise<{
  files: GeneratedFile[];
  assetBundle: { assets: BundledAsset[]; manifest: string; totalSize: number };
}> {
  console.log('[Export] Starting Babylon.js export for world:', worldId);
  
  // 1. Generate the World IR
  console.log('[Export] Generating World IR...');
  const ir = await generateWorldIR(worldId);
  
  // 2. Get the world's selected asset collection
  const { storage } = await import(/* webpackIgnore: true */ new URL('../../../db/storage.js', import.meta.url).href as any);
  const world = await storage.getWorld(worldId);
  const selectedCollectionId = (world as any)?.selectedAssetCollectionId;
  
  // 3. Generate data files
  console.log('[Export] Generating data files...');
  const dataFiles = generateDataFiles(ir);
  
  // 4. Generate scene files
  console.log('[Export] Generating scene files...');
  const sceneFiles = generateSceneFiles(ir);
  
  // 5. Copy actual game files from 3DGame directory
  console.log('[Export] Copying game files from 3DGame...');
  const gameFileCopier = new GameFileCopier(
    get3DGamePath(),
    '/tmp/export'
  );
  const gameFiles = await gameFileCopier.copyAllFiles();
  
  // 6. Copy shared types
  console.log('[Export] Copying shared types...');
  const sharedTypesFiles = await copySharedTypes();
  
  // 7. Generate project configuration files
  console.log('[Export] Generating project files...');
  const projectFiles = generateProjectFiles(ir, options);
  
  // 7. Create the DataSource file for file-based loading
  const dataSourceTemplate = await fs.readFile(
    path.join(__dirname, 'templates', 'DataSource.ts'),
    'utf8'
  );
  const dataSourceFile: GeneratedFile = {
    path: 'src/DataSource.ts',
    content: dataSourceTemplate
  };
  
  // 8. Create the index file that exports BabylonGame
  const indexTemplate = await fs.readFile(
    path.join(__dirname, 'templates', 'index.ts'),
    'utf8'
  );
  const indexFile: GeneratedFile = {
    path: 'src/index.ts',
    content: indexTemplate
  };
  
  // 9. Create the main entry file that uses the real game
  const mainEntryFile: GeneratedFile = {
    path: 'src/main.ts',
    content: generateMainEntry(ir)
  };
  
  // 10. Bundle assets from the world's selected collection
  console.log('[Export] Bundling assets...');
  let assetBundle;
  if (selectedCollectionId) {
    console.log(`[Export] Using asset collection: ${selectedCollectionId}`);
    assetBundle = await bundleAssetsFromCollection(selectedCollectionId);
    
    // If no assets were bundled from the collection, fall back to core assets
    if (assetBundle.assets.length === 0) {
      console.log('[Export] Collection had no assets, falling back to core assets');
      assetBundle = await bundleCoreAssets();
    }
  } else {
    console.log('[Export] No asset collection selected, using core assets');
    assetBundle = await bundleCoreAssets();
  }
  
  // 11. Generate asset manifest
  const manifestJson = generateAssetManifestJson(assetBundle.manifest);
  
  // Combine all files
  const allFiles: GeneratedFile[] = [
    ...dataFiles,
    ...sceneFiles,
    ...gameFiles,
    ...sharedTypesFiles,
    dataSourceFile,
    indexFile,
    mainEntryFile,
    ...projectFiles,
    { path: 'public/data/asset-manifest.json', content: manifestJson },
  ];
  
  // For Electron mode, create temp directory and build the app
  let projectDir: string | undefined;
  if (options.mode === 'electron') {
    console.log('[Export] Building Electron app...');
    projectDir = await mkdtemp(join(tmpdir(), 'babylon-export-'));
    
    // Write all files to temp directory
    console.log(`[Export] Writing ${allFiles.length} files to ${projectDir}`);
    console.log(`[Export] Shared types files count: ${sharedTypesFiles.length}`);
    for (const file of allFiles) {
      const filePath = join(projectDir, file.path);
      await fsMkdir(path.dirname(filePath), { recursive: true });
      await fsWriteFile(filePath, file.content, 'utf8');
      
      // Debug: Log important files
      if (file.path.includes('TextureManager') || file.path.includes('tsconfig') || file.path.includes('vite.config') || file.path.includes('shared/') || file.path.includes('DataSource')) {
        console.log(`[Export] Wrote ${file.path}`);
      }
    }
    
    // Write binary assets
    for (const asset of assetBundle.assets) {
      const assetPath = path.join(projectDir, 'public', asset.exportPath);
      await fsMkdir(path.dirname(assetPath), { recursive: true });
      await fsWriteFile(assetPath, asset.buffer);
    }
    
    // Create a simple icon file for Electron
    const iconPath = path.join(projectDir, 'public', 'icon.png');
    await fsMkdir(path.dirname(iconPath), { recursive: true });
    const iconBuffer = Buffer.from([
      0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
      // Minimal PNG header (would need actual PNG data)
    ]);
    await fsWriteFile(iconPath, iconBuffer);
    
    // Build the Electron app
    const builtAppPath = await buildElectronApp(projectDir);
    
    // Add the built app to the files list
    await addBuiltAppToFiles(builtAppPath, allFiles);
    
    // Clean up temp directory
    await rm(projectDir, { recursive: true, force: true });
  }
  
  console.log('[Export] Babylon.js export completed successfully');
  
  return {
    files: allFiles,
    assetBundle: {
      assets: assetBundle.assets,
      manifest: manifestJson,
      totalSize: assetBundle.totalSizeBytes,
    },
  };
}

/**
 * Export as ZIP buffer
 */
export async function exportBabylonProjectAsZip(worldId: string, options: BabylonExportOptions = { mode: 'web' }): Promise<Buffer> {
  // Lazy load archiver
  if (!archiver) {
    try {
      archiver = require('archiver');
    } catch (e) {
      throw new Error('Archiver not available. Install with: npm install archiver');
    }
  }
  
  const { files, assetBundle } = await exportBabylonProject(worldId, options);
  
  return new Promise((resolve, reject) => {
    const chunks: Buffer[] = [];
    const archive = archiver('zip', { zlib: { level: 9 } });
    
    archive.on('data', (chunk: Buffer) => chunks.push(chunk));
    archive.on('end', () => resolve(Buffer.concat(chunks)));
    archive.on('error', reject);
    
    // Add text files
    files.forEach(file => {
      const data = Buffer.isBuffer(file.content) ? file.content : Buffer.from(file.content, 'utf8');
      archive.append(data, { name: file.path });
    });
    
    // Add binary assets
    assetBundle.assets.forEach(asset => {
      archive.append(asset.buffer, { name: `public/${asset.exportPath}` });
    });
    
    archive.finalize();
  });
}

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function generateAssetManifestJson(manifest: any[]): string {
  const categories: Record<string, any[]> = {};
  
  for (const asset of manifest) {
    if (!categories[asset.category]) {
      categories[asset.category] = [];
    }
    categories[asset.category].push(asset);
  }
  
  return JSON.stringify({
    version: "1.0.0",
    description: "Insimul Base Collection — bundled assets",
    totalFiles: manifest.length,
    totalSizeBytes: manifest.reduce((sum, asset) => sum + asset.fileSize, 0),
    categories,
    assets: manifest
  }, null, 2);
}

async function buildElectronApp(projectDir: string): Promise<string> {
  console.log('[Electron] Building app...');
  
  // Change to project directory
  process.chdir(projectDir);
  
  // Install dependencies
  console.log('[Electron] Installing dependencies...');
  execSync('npm install', { stdio: 'inherit' });
  
  // Build the app
  console.log('[Electron] Running build...');
  execSync('npm run build', { stdio: 'inherit' });
  
  // Package with electron-builder
  console.log('[Electron] Packaging with electron-builder...');
  execSync('npx electron-builder --publish=never', { stdio: 'inherit' });
  
  return path.join(projectDir, 'release');
}

async function addBuiltAppToFiles(builtAppPath: string, files: GeneratedFile[]): Promise<void> {
  // This would add the built app files to the files list
  // For now, we'll just log it
  console.log(`[Electron] Built app at: ${builtAppPath}`);
}

function get3DGamePath(): string {
  // Get the path to the 3DGame directory
  return path.join(__dirname, '..', '..', '..', '..', 'client', 'src', 'components', '3DGame');
}

function generateMainEntry(ir: WorldIR): string {
  return `/**
 * Main Entry Point for Exported Babylon.js Game
 * Generated by Insimul — ${ir.meta.worldName}
 */

import { Engine } from '@babylonjs/core/Engines/engine';
import '@babylonjs/loaders';
import '@babylonjs/core/Helpers/sceneHelpers';

// Import the actual BabylonGame class
import { BabylonGame } from './index';
import { createDataSource } from './DataSource';

// Canvas setup
const canvas = document.getElementById('renderCanvas') as HTMLCanvasElement;
if (!canvas) throw new Error('Canvas not found');

// Create engine
const engine = new Engine(canvas, true);

// Create file-based data source for exported game
const dataSource = createDataSource();

// Create and initialize the game with the real BabylonGame class
const game = new BabylonGame(canvas, {
  worldId: '${ir.meta.worldId}',
  worldName: '${ir.meta.worldName}',
  worldType: '${ir.meta.worldType || 'fantasy'}',
  dataSource: dataSource // Use file-based data source
});

// Initialize and start the game
game.init().then(() => {
  console.log('[Insimul] ${ir.meta.worldName} loaded successfully.');
  
  // Hide loading screen
  const loadingScreen = document.getElementById('loadingScreen');
  if (loadingScreen) {
    loadingScreen.classList.add('hidden');
  }
  
  // Start render loop
  engine.runRenderLoop(() => {
    if (game.scene && game.engine) {
      game.scene.render();
    }
  });
}).catch(error => {
  console.error('Failed to initialize game:', error);
  
  // Show error message
  const loadingScreen = document.getElementById('loadingScreen');
  if (loadingScreen) {
    loadingScreen.innerHTML = \`
      <div style="color: white; text-align: center; padding: 20px;">
        <h1>Error Loading Game</h1>
        <p>\${error.message || 'Unknown error'}</p>
      </div>
    \`;
  }
});

// Handle window resize
window.addEventListener('resize', () => {
  engine.resize();
});
`;

function generateDataSource(): string {
  return `/**
 * Data Layer Abstraction for BabylonGame
 * 
 * This interface allows BabylonGame to work with both API-based data (in Insimul)
 * and file-based data (in exported games).
 */

export interface DataSource {
  loadWorld(worldId: string): Promise<any>;
  loadCharacters(worldId: string): Promise<any[]>;
  loadActions(worldId: string): Promise<any[]>;
  loadBaseActions(): Promise<any[]>;
  loadQuests(worldId: string): Promise<any[]>;
  loadSettlements(worldId: string): Promise<any[]>;
  loadRules(worldId: string): Promise<any[]>;
  loadBaseRules(): Promise<any[]>;
  loadCountries(worldId: string): Promise<any[]>;
  loadStates(worldId: string): Promise<any[]>;
  loadBaseResources(worldId: string): Promise<any>;
  loadAssets(worldId: string): Promise<any[]>;
  loadConfig3D(worldId: string): Promise<any>;
  loadTruths(worldId: string): Promise<any[]>;
  loadCharacter(characterId: string): Promise<any>;
  startPlaythrough(worldId: string, authToken: string, playthroughName: string): Promise<any>;
  updateQuest(questId: string, data: any): Promise<void>;
  loadSettlementBusinesses(settlementId: string): Promise<any[]>;
  loadSettlementLots(settlementId: string): Promise<any[]>;
  loadSettlementResidences(settlementId: string): Promise<any[]>;
  payFines(playthroughId: string, settlementId: string): Promise<any>;
}

/**
 * File-based data source for exported games
 */
export class FileDataSource implements DataSource {
  private worldData: any = null;
  private worldIR: any = null;

  constructor() {
    // Load world data from files
    this.loadWorldData();
  }

  private async loadWorldData(): Promise<void> {
    try {
      // Load the world IR
      const irResponse = await fetch('/data/world_ir.json');
      this.worldIR = await irResponse.json();
      
      // Load the full world data - combine character and other data
      const [characterResponse, geographyResponse, actionsResponse, questsResponse, npcsResponse, rulesResponse, truthsResponse] = await Promise.all([
        fetch('/data/characters.json'),
        fetch('/src/data/geography.json'),
        fetch('/src/data/actions.json'),
        fetch('/src/data/quests.json'),
        fetch('/src/data/npcs.json'),
        fetch('/src/data/rules.json'),
        fetch('/data/truths.json')
      ]);
      
      const [characters, geography, actions, quests, npcs, rules, truths] = await Promise.all([
        characterResponse.json(),
        geographyResponse.json(),
        actionsResponse.json(),
        questsResponse.json(),
        npcsResponse.json(),
        rulesResponse.json(),
        truthsResponse.json()
      ]);
      
      // Combine into worldData structure
      this.worldData = {
        characters,
        geography,
        actions,
        quests,
        npcs,
        rules,
        truths
      };
      
      console.log('[FileDataSource] Loaded world data from files');
    } catch (error) {
      console.error('[FileDataSource] Failed to load world data:', error);
    }
  }

/**
 * Factory to create the appropriate data source
 */
export function createDataSource(authToken?: string): DataSource {
  // Check if we're in an exported environment (no API available)
  if (typeof window !== 'undefined' && window.location?.protocol === 'file:') {
    return new FileDataSource();
  }
  
  // Default to file-based for exports
  return new FileDataSource();
}

      execSync('npx electron-builder --win --publish=never', { cwd: projectDir, stdio: 'inherit' });
    } catch (error: any) {
      if (error.status === 127) {
        console.log('[Electron] Wine not found - skipping Windows build');
        console.log('[Electron] To enable Windows builds on macOS, install Wine:');
        console.log('[Electron]   brew install --cask wine-stable');
      } else {
        console.log('[Electron] Windows build failed');
      }
    }
  }
  
  // Try cross-compilation for Linux
  if (process.platform !== 'linux') {
    console.log('[Electron] Attempting Linux build...');
    try {
      execSync('npx electron-builder --linux --publish=never', { cwd: projectDir, stdio: 'inherit' });
    } catch (error) {
      console.log('[Electron] Linux build failed');
    }
  }
  
  // Return the release directory where electron-builder puts the packaged apps
  const releaseDir = join(projectDir, 'release');
  return releaseDir;
}

async function addBuiltAppToFiles(appPath: string, files: GeneratedFile[]): Promise<void> {
  console.log('[Electron] Adding built app to files...');
  console.log(`[Electron] App path: ${appPath}`);
  
  // The appPath is the release directory, so we need to go up to get the project root
  const projectRoot = path.join(appPath, '..');
  
  // First add the source files (for development)
  const distPath = path.join(projectRoot, 'dist');
  const packageJsonPath = path.join(projectRoot, 'package.json');
  const electronPath = path.join(projectRoot, 'electron');
  const publicPath = path.join(projectRoot, 'public');
  
  console.log(`[Electron] Dist path exists: ${fs.existsSync(distPath)}`);
  console.log(`[Electron] Package.json exists: ${fs.existsSync(packageJsonPath)}`);
  console.log(`[Electron] Electron dir exists: ${fs.existsSync(electronPath)}`);
  console.log(`[Electron] Public dir exists: ${fs.existsSync(publicPath)}`);
  
  // Add package.json
  if (fs.existsSync(packageJsonPath)) {
    const packageJson = fs.readFileSync(packageJsonPath, 'utf8');
    files.push({
      path: 'package.json',
      content: packageJson
    });
    console.log('[Electron] Added package.json');
  }
  
  // Add dist directory
  if (fs.existsSync(distPath)) {
    const addDistFiles = function(dir: string, basePath: string = ''): void {
      const entries = fs.readdirSync(dir, { withFileTypes: true });
      
      for (const entry of entries) {
        const fullPath = path.join(dir, entry.name);
        const relativePath = basePath ? path.join(basePath, entry.name) : entry.name;
        
        if (entry.isDirectory()) {
          addDistFiles(fullPath, relativePath);
        } else {
          const content = fs.readFileSync(fullPath);
          files.push({
            path: path.join('dist', relativePath),
            content: content,
            isBinary: true
          });
          console.log(`[Electron] Added dist file: dist/${relativePath}`);
        }
      }
    };
    
    addDistFiles(distPath);
    console.log('[Electron] Added dist directory');
  }
  
  // Add electron directory
  if (fs.existsSync(electronPath)) {
    const addElectronFiles = function(dir: string, basePath: string = ''): void {
      const entries = fs.readdirSync(dir, { withFileTypes: true });
      
      for (const entry of entries) {
        const fullPath = path.join(dir, entry.name);
        const relativePath = basePath ? path.join(basePath, entry.name) : entry.name;
        
        if (entry.isDirectory()) {
          addElectronFiles(fullPath, relativePath);
        } else {
          const content = fs.readFileSync(fullPath, 'utf8');
          files.push({
            path: path.join('electron', relativePath),
            content: content
          });
          console.log(`[Electron] Added electron file: electron/${relativePath}`);
        }
      }
    };
    
    addElectronFiles(electronPath);
    console.log('[Electron] Added electron directory');
  }
  
  // Add public directory (includes data files)
  if (fs.existsSync(publicPath)) {
    const addPublicFiles = function(dir: string, basePath: string = ''): void {
      const entries = fs.readdirSync(dir, { withFileTypes: true });
      
      for (const entry of entries) {
        const fullPath = path.join(dir, entry.name);
        const relativePath = basePath ? path.join(basePath, entry.name) : entry.name;
        
        if (entry.isDirectory()) {
          addPublicFiles(fullPath, relativePath);
        } else {
          const content = fs.readFileSync(fullPath);
          files.push({
            path: path.join('public', relativePath),
            content: content,
            isBinary: true
          });
          console.log(`[Electron] Added public file: public/${relativePath}`);
        }
      }
    };
    
    addPublicFiles(publicPath);
    console.log('[Electron] Added public directory');
  }
  
  // Now add the packaged distributables from the release directory
  if (fsSync.existsSync(appPath)) {
    // Add distributable files (.dmg, .exe, etc.)
    const entries = fsSync.readdirSync(appPath, { withFileTypes: true });
    
    for (const entry of entries) {
      if (entry.isFile() && (entry.name.endsWith('.dmg') || entry.name.endsWith('.exe') || 
          entry.name.endsWith('.AppImage') || entry.name.endsWith('.deb') || entry.name.endsWith('.rpm') ||
          entry.name.endsWith('.zip'))) {
        const fullPath = path.join(appPath, entry.name);
        const content = fsSync.readFileSync(fullPath);
        files.push({
          path: path.join('release', entry.name),
          content: content,
          isBinary: true
        });
        console.log(`[Electron] Added release file: release/${entry.name}`);
      }
    }
    
    // Also add unpackaged app directories for quick testing
    const appDirs = entries.filter(e => e.isDirectory() && 
      (e.name === 'mac' || e.name === 'win' || e.name === 'linux' || e.name.startsWith('French Louisiana')));
    
    for (const dir of appDirs) {
      const addAppDir = function(dirPath: string, basePath: string = ''): void {
        try {
          const dirEntries = fs.readdirSync(dirPath, { withFileTypes: true });
          
          for (const entry of dirEntries) {
            const fullPath = path.join(dirPath, entry.name);
            const relativePath = basePath ? path.join(basePath, entry.name) : entry.name;
            
            // Skip hidden files and certain system directories
            if (entry.name.startsWith('.') || 
                entry.name === '__MACOSX' ||
                entry.name === 'node_modules' ||
                entry.name.endsWith('.DS_Store')) {
              continue;
            }
            
            if (entry.isDirectory()) {
              addAppDir(fullPath, relativePath);
            } else {
              try {
                const content = fs.readFileSync(fullPath);
                files.push({
                  path: path.join('release', dir.name, relativePath),
                  content: content,
                  isBinary: true
                });
                console.log(`[Electron] Added app file: release/${dir.name}/${relativePath}`);
              } catch (fileError: any) {
                console.warn(`[Electron] Skipping file ${fullPath}:`, fileError?.message || fileError);
              }
            }
          }
        } catch (dirError: any) {
          console.warn(`[Electron] Skipping directory ${dirPath}:`, dirError?.message || dirError);
        }
      };
      
      addAppDir(path.join(appPath, dir.name));
      console.log(`[Electron] Added app directory: release/${dir.name}`);
    }
    
    console.log('[Electron] Added release directory with packaged apps');
  }
  
  console.log(`[Electron] Total files after adding build: ${files.length}`);
}
