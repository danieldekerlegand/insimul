# MongoDB Connection
MONGO_URL=mongodb://localhost:27017/insimul

# Google Gemini API Key (required for character chat and contextual name generation)
# Get your API key from: https://makersuite.google.com/app/apikey
# Can be set as GEMINI_API_KEY or GEMINI_FREE_API_KEY (both work)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_FREE_API_KEY=your_gemini_api_key_here

# Image Generation API Keys (optional, for visual asset generation)
# Replicate API Key - supports Stable Diffusion and Flux models
# Get your key from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here

# OpenAI API Key - supports DALL-E 2 and DALL-E 3
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Stable Diffusion API Key (alternative to Replicate)
# If you have a direct Stable Diffusion API endpoint
STABLE_DIFFUSION_API_KEY=your_sd_api_key_here

# Freesound API Key (for audio asset integration)
# Get your API key from: https://freesound.org/apiv2/apply
FREESOUND_CLIENT_ID=your_freesound_client_id_here
FREESOUND_API_KEY=your_freesound_api_key_here

# Local Speech-to-Text (whisper.cpp)
# Path to the whisper.cpp binary (e.g. /usr/local/bin/whisper-cpp or ./whisper.cpp/main)
WHISPER_CPP_PATH=whisper-cpp
# Path to the Whisper GGML model file (required for local STT)
# Download models from: https://huggingface.co/ggerganov/whisper.cpp/tree/main
WHISPER_MODEL_PATH=
# Model size label: tiny, base, small, medium, large (default: base)
WHISPER_MODEL_SIZE=base

# Server Configuration
PORT=3000

# Database Initialization
# Automatically initialize database if empty (default: true)
AUTO_INIT=true

# Automatically seed sample Talk of the Town world when initializing (default: true)
AUTO_SEED=true
