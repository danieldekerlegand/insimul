{
  "name": "insimul-export-la_louisiane",
  "version": "1.0.0",
  "private": true,
  "description": "A contemporary modern world with real-world issues and challenges",
  "author": "InSimul",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite build && electron .",
    "dev:web": "vite",
    "dev:vite": "vite & electron . --dev",
    "build": "vite build",
    "build:web": "vite build",
    "package:web": "npm run build && cd dist && zip -r ../web-build.zip .",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron . --dev\""
  },
  "dependencies": {
    "@babylonjs/core": "^7.0.0",
    "@babylonjs/gui": "^7.0.0",
    "@babylonjs/loaders": "^7.0.0",
    "@babylonjs/materials": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.insimul.la_louisiane",
    "productName": "La Louisiane",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "electron/ai-service.js",
      "electron/whisper-stt.js",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "category": "public.app-category.games",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}